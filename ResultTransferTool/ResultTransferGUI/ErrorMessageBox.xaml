<Window x:Class="ResultTransferGUI.ErrorMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ResultTransferGUI"
        mc:Ignorable="d"
        Title="ErrorMessageBox" Height="300" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="Result Transfer Tool Meets Error:" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FF6ECD2A"></Label>
        <Label Grid.Row="1" Name="MessageContainer" Content="Empty" HorizontalContentAlignment="Left"></Label>
        <Button Grid.Row="2" Name="CloseBtn" Click="CloseBtn_Click">Close</Button>
    </Grid>
</Window>
